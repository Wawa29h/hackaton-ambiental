# ── IA ──────────────────────────────────────────────────────────────────────
# OpenRouter — genera predicciones de pesca y alertas para pescadores
OPENROUTER_KEY=sk-or-v1-...

# ── NOAA ────────────────────────────────────────────────────────────────────
# NOAA Coral Reef Watch — datos satelitales de temperatura y blanqueamiento
NOAA_API_KEY=

# ── Copernicus Marine Service ────────────────────────────────────────────────
# Registro gratuito en: https://marine.copernicus.eu/
# Datos: temperatura, corrientes, salinidad, forecast 14 días
COPERNICUS_USER=tu_usuario_copernicus
COPERNICUS_PASSWORD=tu_password_copernicus

# ── Frontend Vite ────────────────────────────────────────────────────────────
# URL del backend FastAPI (uvicorn corre en 8000 por defecto)
VITE_API_URL=http://localhost:8000
